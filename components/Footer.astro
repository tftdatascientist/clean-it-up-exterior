---
import { BRAND } from '../config/brand';
const year = new Date().getFullYear();
---

<footer class="bg-dark text-white">
  <div class="container-main section-padding">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div>
        <h3 class="text-xl font-heading font-bold mb-4">{BRAND.NAME}</h3>
        <p class="text-gray-300 mb-4">{BRAND.TAGLINE}</p>
        <p class="text-gray-400 text-sm">{BRAND.ADDRESS}</p>
      </div>

      <div>
        <h4 class="text-lg font-heading font-bold mb-4">Quick Links</h4>
        <ul class="space-y-2">
          <li><a href="/" class="text-gray-300 hover:text-white transition-colors">Home</a></li>
          {BRAND.SERVICES.map(s => (
            <li><a href={`/${s.slug}`} class="text-gray-300 hover:text-white transition-colors">{s.name}</a></li>
          ))}
          <li><a href="/gallery" class="text-gray-300 hover:text-white transition-colors">Gallery</a></li>
          <li><a href="/about" class="text-gray-300 hover:text-white transition-colors">About</a></li>
          <li><a href="/contact" class="text-gray-300 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-lg font-heading font-bold mb-4">Contact Us</h4>
        <ul class="space-y-3 text-gray-300">
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <a href={`tel:${BRAND.PHONE}`} class="hover:text-white transition-colors">{BRAND.PHONE}</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href={`mailto:${BRAND.EMAIL}`} class="hover:text-white transition-colors">{BRAND.EMAIL}</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>{BRAND.HOURS}</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-gray-700">
    <div class="container-main flex flex-col md:flex-row justify-between items-center py-6 px-4 md:px-8 text-sm text-gray-400 gap-4">
      <p>&copy; {year} {BRAND.NAME}. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
