---
import { BRAND } from '../config/brand';
---

<section class="bg-primary text-white py-16 px-4">
  <div class="container-main text-center">
    <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">Ready for a Cleaner Home?</h2>
    <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">Get your free, no-obligation quote today. We're available evenings and weekends to suit your schedule.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a href="/contact" class="btn-primary text-lg px-8 py-4 bg-accent hover:bg-accent-600">Get a Free Quote</a>
      <a href={`tel:${BRAND.PHONE}`} class="text-white text-xl font-heading font-bold hover:text-accent transition-colors flex items-center gap-2">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        {BRAND.PHONE}
      </a>
    </div>
  </div>
</section>
