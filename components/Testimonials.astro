---
const reviews = [
  {
    name: 'Sarah M.',
    location: 'Gloucester',
    text: 'Absolutely brilliant job on our roof. The moss was terrible and now it looks brand new. Very professional and tidy — highly recommend!',
    stars: 5,
  },
  {
    name: 'David P.',
    location: 'Cheltenham',
    text: 'Had the gutters and fascias done. Quick, efficient, and the results were fantastic. Great to have someone local and reliable.',
    stars: 5,
  },
  {
    name: 'Jane & Tom W.',
    location: 'Stroud',
    text: 'Our solar panels are producing noticeably more since the clean. The pure water method is really impressive — no marks at all.',
    stars: 5,
  },
];
---

<section class="section-padding bg-white">
  <div class="container-main">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark mb-4">What Our Customers Say</h2>
      <p class="text-gray-500 text-sm">(Placeholder reviews — to be replaced with genuine testimonials)</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {reviews.map(review => (
        <div class="bg-light rounded-xl p-6 border border-gray-100">
          <div class="flex gap-1 mb-4">
            {Array.from({ length: review.stars }).map(() => (
              <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-gray-700 mb-4 leading-relaxed italic">"{review.text}"</p>
          <div>
            <p class="font-heading font-bold text-dark">{review.name}</p>
            <p class="text-gray-500 text-sm">{review.location}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
