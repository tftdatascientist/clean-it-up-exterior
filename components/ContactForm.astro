---
import { BRAND } from '../config/brand';
---

<section class="section-padding bg-white" id="contact">
  <div class="container-main">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark mb-4">Get a Free Quote</h2>
        <p class="text-gray-600 text-lg mb-8">Fill in the form below and we'll get back to you within 24 hours. No obligation, no pressure.</p>

        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <p class="font-heading font-bold text-dark">Phone</p>
              <a href={`tel:${BRAND.PHONE}`} class="text-primary hover:underline">{BRAND.PHONE}</a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary shrink-0">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.614.614l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22a9.94 9.94 0 01-5.39-1.583l-.386-.234-2.655.89.89-2.655-.234-.386A9.94 9.94 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            </div>
            <div>
              <p class="font-heading font-bold text-dark">WhatsApp</p>
              <a href={`https://wa.me/${BRAND.WHATSAPP}`} class="text-secondary hover:underline" target="_blank" rel="noopener">Message us on WhatsApp</a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center text-accent shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <p class="font-heading font-bold text-dark">Working Hours</p>
              <p class="text-gray-600">{BRAND.HOURS}</p>
            </div>
          </div>
        </div>
      </div>

      <form action="https://formspree.io/f/PLACEHOLDER" method="POST" class="bg-light rounded-2xl p-6 md:p-8 border border-gray-100">
        <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

        <div class="space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium text-dark mb-1">Full Name *</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" placeholder="Your name" />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="phone" class="block text-sm font-medium text-dark mb-1">Phone *</label>
              <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" placeholder="07XXX XXXXXX" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-dark mb-1">Email</label>
              <input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" placeholder="you@example.com" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="service" class="block text-sm font-medium text-dark mb-1">Service Required *</label>
              <select id="service" name="service" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all bg-white">
                <option value="">Select a service</option>
                <option value="roof">Roof Cleaning</option>
                <option value="gutter">Gutter Cleaning</option>
                <option value="solar">Solar Panel Cleaning</option>
                <option value="render">Render & Facade Cleaning</option>
                <option value="fascias">Fascias, Soffits & uPVC</option>
                <option value="conservatory">Conservatory Cleaning</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label for="postcode" class="block text-sm font-medium text-dark mb-1">Postcode *</label>
              <input type="text" id="postcode" name="postcode" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" placeholder="GL1 1AA" />
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-dark mb-1">Message</label>
            <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all resize-none" placeholder="Tell us about the job..."></textarea>
          </div>

          <button type="submit" class="btn-primary w-full text-lg py-4">Send Free Quote Request</button>
          <p class="text-xs text-gray-500 text-center">We'll get back to you within 24 hours. Your details are safe — see our <a href="/privacy" class="underline">Privacy Policy</a>.</p>
        </div>
      </form>
    </div>
  </div>
</section>
