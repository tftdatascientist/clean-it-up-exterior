---
import { BRAND } from '../config/brand';

const iconSvgs: Record<string, string> = {
  droplet: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21a8 8 0 008-8c0-4.418-8-12-8-12S4 8.582 4 13a8 8 0 008 8z"/></svg>',
  wrench: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.42 15.17l-5.58 5.58a2.121 2.121 0 01-3-3l5.58-5.58m0 0L3.87 7.63a1.5 1.5 0 010-2.12l.5-.5a1.5 1.5 0 012.12 0l4.93 4.93m0 0l4.24-4.24m1.41 1.41l-4.24 4.24m4.24-4.24l2.12 2.12a1.5 1.5 0 010 2.12l-.5.5a1.5 1.5 0 01-2.12 0l-2.12-2.12"/></svg>',
  shield: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>',
  quote: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>',
};
---

<section class="section-padding bg-light">
  <div class="container-main">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark mb-8">Why Choose Us?</h2>
        <div class="space-y-6">
          {BRAND.USP.map(item => (
            <div class="flex gap-4">
              <div class="shrink-0 w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
                <Fragment set:html={iconSvgs[item.icon]} />
              </div>
              <div>
                <h3 class="text-lg font-heading font-bold text-dark mb-1">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="relative">
        <div class="aspect-[4/3] rounded-2xl bg-gray-200 overflow-hidden">
          <div class="w-full h-full flex items-center justify-center text-gray-400">
            <div class="text-center">
              <svg class="w-16 h-16 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <p class="text-sm">Equipment & team photo</p>
            </div>
          </div>
        </div>
        <div class="absolute -bottom-4 -right-4 bg-accent text-white rounded-xl px-6 py-3 font-heading font-bold shadow-lg">
          10+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>
