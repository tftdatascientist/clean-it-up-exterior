---
import { BRAND } from '../config/brand';
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm transition-shadow duration-300">
  <div class="container-main flex items-center justify-between h-16 md:h-20 px-4 md:px-8">
    <a href="/" class="flex items-center gap-2">
      <span class="text-xl md:text-2xl font-heading font-extrabold text-primary">{BRAND.NAME}</span>
    </a>

    <nav class="hidden lg:flex items-center gap-8">
      <a href="/" class="text-dark hover:text-primary transition-colors font-medium">Home</a>
      <div class="relative group">
        <button class="text-dark hover:text-primary transition-colors font-medium flex items-center gap-1">
          Services
          <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full left-0 mt-2 w-56 bg-white rounded-lg shadow-xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2">
          {BRAND.SERVICES.map(s => (
            <a href={`/${s.slug}`} class="block px-4 py-2.5 text-dark hover:bg-primary/5 hover:text-primary transition-colors">{s.name}</a>
          ))}
        </div>
      </div>
      <a href="/gallery" class="text-dark hover:text-primary transition-colors font-medium">Gallery</a>
      <a href="/about" class="text-dark hover:text-primary transition-colors font-medium">About</a>
      <a href="/contact" class="text-dark hover:text-primary transition-colors font-medium">Contact</a>
    </nav>

    <div class="hidden lg:block">
      <a href="/contact" class="btn-primary">Get a Free Quote</a>
    </div>

    <button id="menu-toggle" class="lg:hidden p-2 text-dark" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>

  <div id="mobile-menu" class="lg:hidden hidden bg-white border-t border-gray-100">
    <nav class="container-main flex flex-col py-4 px-4 gap-1">
      <a href="/" class="py-3 px-4 rounded-lg hover:bg-primary/5 text-dark font-medium">Home</a>
      {BRAND.SERVICES.map(s => (
        <a href={`/${s.slug}`} class="py-3 px-4 rounded-lg hover:bg-primary/5 text-dark pl-8">{s.name}</a>
      ))}
      <a href="/gallery" class="py-3 px-4 rounded-lg hover:bg-primary/5 text-dark font-medium">Gallery</a>
      <a href="/about" class="py-3 px-4 rounded-lg hover:bg-primary/5 text-dark font-medium">About</a>
      <a href="/contact" class="py-3 px-4 rounded-lg hover:bg-primary/5 text-dark font-medium">Contact</a>
      <a href="/contact" class="btn-primary mt-2 text-center">Get a Free Quote</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
