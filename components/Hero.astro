---
import { BRAND } from '../config/brand';
---

<section class="relative bg-dark text-white min-h-[90vh] flex items-center mt-16 md:mt-20">
  <div class="absolute inset-0 bg-gradient-to-r from-dark/90 to-dark/60 z-10"></div>
  <div class="absolute inset-0 bg-[url('/images/hero-placeholder.jpg')] bg-cover bg-center"></div>

  <div class="relative z-20 container-main px-4 md:px-8 py-20">
    <div class="max-w-2xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-extrabold leading-tight mb-6">
        Professional Exterior Cleaning in <span class="text-secondary">Gloucester</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-200 mb-8 leading-relaxed">
        Roofs &bull; Gutters &bull; Solar Panels &bull; Facades — Pure Water, Spotless Results.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 mb-12">
        <a href="/contact" class="btn-primary text-lg px-8 py-4">Get a Free Quote</a>
        <a href={`tel:${BRAND.PHONE}`} class="btn-outline text-lg px-8 py-4">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call Now
        </a>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { icon: '🛡️', text: 'Fully Insured' },
          { icon: '💧', text: 'Pure Water System' },
          { icon: '📋', text: 'Free Quotes' },
          { icon: '🌙', text: 'Evenings & Weekends' },
        ].map(badge => (
          <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-lg px-3 py-2.5 text-sm">
            <span class="text-lg">{badge.icon}</span>
            <span class="font-medium">{badge.text}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
