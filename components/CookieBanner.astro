<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-50 bg-dark text-white p-4 shadow-2xl transform translate-y-full transition-transform duration-300" role="alert">
  <div class="container-main flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-gray-300">
      We use essential cookies only to make this site work. No tracking or advertising cookies.
      <a href="/privacy" class="underline text-white hover:text-accent">Privacy Policy</a>
    </p>
    <button id="cookie-accept" class="shrink-0 bg-accent hover:bg-accent-600 text-white px-5 py-2 rounded-lg font-bold text-sm transition-colors">
      Accept
    </button>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const btn = document.getElementById('cookie-accept');

  if (!localStorage.getItem('cookies-accepted')) {
    setTimeout(() => banner?.classList.remove('translate-y-full'), 500);
  }

  btn?.addEventListener('click', () => {
    localStorage.setItem('cookies-accepted', 'true');
    banner?.classList.add('translate-y-full');
  });
</script>
