---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';
import { BRAND } from '../config/brand';
---

<BaseLayout title="About Us" description={`Learn about ${BRAND.NAME} — professional exterior cleaning in ${BRAND.SERVICE_AREA}. Fully equipped, fully insured, locally based.`}>
  <Header slot="header" />

  <div class="mt-16 md:mt-20 bg-primary text-white py-16 px-4">
    <div class="container-main">
      <h1 class="text-4xl md:text-5xl font-heading font-extrabold mb-4">About Us</h1>
      <p class="text-xl text-blue-100 max-w-3xl">Local, professional and fully equipped — your trusted exterior cleaning specialist in {BRAND.SERVICE_AREA}.</p>
    </div>
  </div>

  <section class="section-padding bg-white">
    <div class="container-main grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-6">Who We Are</h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          {BRAND.NAME} is a professional exterior cleaning service based in Gloucester, serving homeowners across Gloucestershire. We specialise in roof cleaning, gutter clearance, solar panel cleaning and facade restoration.
        </p>
        <p class="text-gray-600 leading-relaxed mb-4">
          We believe in doing things properly — using the right equipment and proven methods to deliver results that last. Our pure water technology means no chemicals, no streaks, and no damage to your property.
        </p>
        <p class="text-gray-600 leading-relaxed">
          As a local, owner-operated business, we take pride in every job. We're fully insured and available evenings and weekends to fit around your schedule.
        </p>
      </div>
      <div class="aspect-[4/3] bg-gray-200 rounded-2xl flex items-center justify-center">
        <div class="text-center text-gray-400">
          <svg class="w-16 h-16 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <p class="text-sm">Team / owner photo</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-light">
    <div class="container-main">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-8 text-center">Our Equipment</h2>
      <p class="text-gray-600 text-lg text-center max-w-2xl mx-auto mb-10">We invest in professional-grade equipment so we can deliver the best results safely and efficiently.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { title: 'Mobile Scaffold Tower', desc: 'Aluminium access tower for safe working at height — up to 3 storeys. No damage to your property.', placeholder: 'Scaffold tower photo' },
          { title: 'Gutter Vacuum System', desc: '3600W industrial gutter vacuum with 40ft carbon fibre reach. Clears gutters safely from ground level.', placeholder: 'Gutter vacuum photo' },
          { title: 'Water-Fed Poles', desc: 'Aquaspray Venom carbon fibre poles + SkyScraper system for pure water reach-and-wash up to 40ft.', placeholder: 'Water-fed pole photo' },
        ].map(eq => (
          <div class="bg-white rounded-xl overflow-hidden border border-gray-100">
            <div class="aspect-[4/3] bg-gray-200 flex items-center justify-center">
              <div class="text-center text-gray-400">
                <svg class="w-12 h-12 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                <p class="text-xs">{eq.placeholder}</p>
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-heading font-bold text-dark mb-2">{eq.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{eq.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer slot="footer" />
</BaseLayout>
