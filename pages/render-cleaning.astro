---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';
import { BRAND } from '../config/brand';

const faqs = [
  { q: 'Is soft wash safe for K-Rend?', a: 'Yes. Soft wash uses low pressure and specialist cleaning solutions that are safe for K-Rend, silicone render, and pebbledash surfaces.' },
  { q: 'What causes the green/red staining on render?', a: 'Green staining is typically algae growth, while red/orange staining is usually red algae or rust from metal fixings. Both respond well to soft wash treatment.' },
  { q: 'How long do results last?', a: 'Typically 2–4 years depending on the orientation of the wall (north-facing walls are more prone to algae) and local conditions.' },
  { q: 'Do you use a pressure washer?', a: 'No — high pressure can damage render. We use a soft wash system that cleans effectively at low pressure, protecting your surfaces.' },
];
---

<BaseLayout title="Render & Facade Cleaning" description="Professional render and facade cleaning in Gloucester. Safe soft wash for K-Rend, silicone render and pebbledash. Remove algae, staining and pollution.">
  <Header slot="header" />

  <div class="mt-16 md:mt-20 bg-primary text-white py-16 px-4">
    <div class="container-main">
      <h1 class="text-4xl md:text-5xl font-heading font-extrabold mb-4">Render & Facade Cleaning</h1>
      <p class="text-xl text-blue-100 max-w-3xl">Gentle soft wash treatment to restore your render and facade. Safe for K-Rend, silicone and pebbledash surfaces.</p>
    </div>
  </div>

  <section class="section-padding bg-white">
    <div class="container-main grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-6">The Problem</h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          Rendered and facades gradually become discoloured by algae, red algae, pollution deposits, and rust streaks from metal fixings. This is particularly common on north and west-facing walls in the UK climate.
        </p>
        <p class="text-gray-600 leading-relaxed">
          Attempting to clean render with a pressure washer often causes damage — blowing holes in the surface or driving water behind the render. Professional soft wash is the only safe and effective solution.
        </p>
      </div>
      <div class="aspect-[4/3] bg-gray-200 rounded-2xl flex items-center justify-center">
        <div class="text-center text-gray-400">
          <svg class="w-16 h-16 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <p class="text-sm">Before/after render cleaning</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-light">
    <div class="container-main">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-8 text-center">Our Method</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { step: '1', title: 'Assessment', desc: 'We identify the type of render and staining to select the right cleaning solution and approach.' },
          { step: '2', title: 'Soft Wash Application', desc: 'Low-pressure application of specialist biodegradable cleaning solution that kills algae and breaks down staining.' },
          { step: '3', title: 'Rinse & Protect', desc: 'Thorough low-pressure rinse reveals the clean surface. Optional protective treatment to slow future regrowth.' },
        ].map(item => (
          <div class="bg-white rounded-xl p-6 border border-gray-100">
            <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-heading font-bold mb-4">{item.step}</div>
            <h3 class="text-lg font-heading font-bold text-dark mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-main max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-8 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <details class="bg-light rounded-xl border border-gray-100 group">
            <summary class="px-6 py-4 cursor-pointer font-heading font-bold text-dark flex justify-between items-center">
              {faq.q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-4 text-gray-600 leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer slot="footer" />
</BaseLayout>
