---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { BRAND } from '../config/brand';
---

<BaseLayout title="Privacy Policy">
  <Header slot="header" />

  <div class="mt-16 md:mt-20 section-padding bg-white">
    <div class="container-main max-w-3xl prose prose-gray">
      <h1 class="text-3xl font-heading font-bold text-dark">Privacy Policy</h1>
      <p class="text-sm text-gray-500">Last updated: April 2026</p>

      <h2>Who we are</h2>
      <p>{BRAND.NAME} is a sole trader exterior cleaning business based in {BRAND.ADDRESS}. We can be contacted at <a href={`mailto:${BRAND.EMAIL}`}>{BRAND.EMAIL}</a>.</p>

      <h2>What data we collect</h2>
      <p>When you contact us via our website form, we collect:</p>
      <ul>
        <li>Your name</li>
        <li>Phone number</li>
        <li>Email address (if provided)</li>
        <li>Postcode</li>
        <li>Details of your enquiry</li>
      </ul>

      <h2>How we use your data</h2>
      <p>We use your personal data solely to:</p>
      <ul>
        <li>Respond to your enquiry and provide a quote</li>
        <li>Arrange and carry out the cleaning service</li>
        <li>Contact you about your booking</li>
      </ul>
      <p>We do not sell, share, or transfer your data to third parties for marketing purposes.</p>

      <h2>Legal basis</h2>
      <p>We process your data on the basis of legitimate interest (responding to your enquiry) and, where applicable, for the performance of a contract.</p>

      <h2>Data retention</h2>
      <p>We retain your contact details for up to 24 months after your last interaction with us, unless you request earlier deletion.</p>

      <h2>Your rights</h2>
      <p>Under UK GDPR, you have the right to:</p>
      <ul>
        <li>Access the personal data we hold about you</li>
        <li>Request correction or deletion of your data</li>
        <li>Object to processing of your data</li>
        <li>Lodge a complaint with the ICO (ico.org.uk)</li>
      </ul>

      <h2>Cookies</h2>
      <p>This website uses only essential cookies required for the site to function. We do not use tracking or advertising cookies.</p>

      <h2>Contact</h2>
      <p>For any data protection queries, contact us at <a href={`mailto:${BRAND.EMAIL}`}>{BRAND.EMAIL}</a>.</p>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
