---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import { BRAND } from '../config/brand';
---

<BaseLayout title="Contact Us" description={`Get a free quote from ${BRAND.NAME}. Professional exterior cleaning services in ${BRAND.SERVICE_AREA}.`}>
  <Header slot="header" />

  <div class="mt-16 md:mt-20 bg-primary text-white py-16 px-4">
    <div class="container-main text-center">
      <h1 class="text-4xl md:text-5xl font-heading font-extrabold mb-4">Contact Us</h1>
      <p class="text-xl text-blue-100 max-w-2xl mx-auto">Get your free, no-obligation quote. We respond within 24 hours.</p>
    </div>
  </div>

  <ContactForm />
  <Footer slot="footer" />
</BaseLayout>
