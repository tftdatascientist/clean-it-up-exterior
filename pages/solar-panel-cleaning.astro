---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';
import { BRAND } from '../config/brand';

const faqs = [
  { q: 'How much efficiency do dirty panels lose?', a: 'Dirty solar panels can lose 15–20% of their output, especially after winter when dust, soot, pollen, and bird droppings accumulate.' },
  { q: 'Is pure water safe for solar panels?', a: 'Absolutely. Deionised (pure) water is the manufacturer-recommended cleaning method. It leaves no residue, no streaks, and won\'t damage panel coatings.' },
  { q: 'How often should panels be cleaned?', a: 'Once or twice a year is ideal — spring (after winter grime) and autumn. More often if you\'re near trees or have bird problems.' },
  { q: 'Will cleaning void my warranty?', a: 'No. Pure water cleaning with soft brushes is the safest method and is endorsed by most panel manufacturers.' },
];
---

<BaseLayout title="Solar Panel Cleaning" description="Professional solar panel cleaning in Gloucester using pure deionised water. Maximise energy output — no detergents, no streaks, safe for coatings.">
  <Header slot="header" />

  <div class="mt-16 md:mt-20 bg-primary text-white py-16 px-4">
    <div class="container-main">
      <h1 class="text-4xl md:text-5xl font-heading font-extrabold mb-4">Solar Panel Cleaning</h1>
      <p class="text-xl text-blue-100 max-w-3xl">Maximise your energy yield with professional pure water cleaning. No detergents, no streaks, no risk to your panels.</p>
    </div>
  </div>

  <section class="section-padding bg-white">
    <div class="container-main grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-6">Why Clean Your Solar Panels?</h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          Winter leaves its mark on your panels. Dust, soot, pollen, bird droppings and melted-snow residue reduce output by <strong>up to 15–20%</strong>. When spring arrives and your system should be generating more, dirty panels hold it back.
        </p>
        <p class="text-gray-600 leading-relaxed mb-4">
          Rain alone doesn't clean panels effectively — it often makes things worse by leaving mineral deposits that bake on in the sun.
        </p>
        <p class="text-gray-600 leading-relaxed">
          Our <strong>pure (deionised) water</strong> method cleans without detergents and dries without streaks — maximising your energy yield and protecting your investment.
        </p>
      </div>
      <div class="aspect-[4/3] bg-gray-200 rounded-2xl flex items-center justify-center">
        <div class="text-center text-gray-400">
          <svg class="w-16 h-16 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <p class="text-sm">Solar panels before/after</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-light">
    <div class="container-main">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-8 text-center">Our Method</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { step: '1', title: 'Pure Water Rinse', desc: 'Deionised water fed through carbon fibre telescopic poles — reaches rooftop panels safely from the ground.' },
          { step: '2', title: 'Soft Brush Agitation', desc: 'Gentle rotating brush loosens baked-on grime without scratching panel surfaces or damaging anti-reflective coatings.' },
          { step: '3', title: 'Spot-Free Dry', desc: 'Pure water evaporates leaving zero mineral deposits, zero streaks — just clean, efficient panels.' },
        ].map(item => (
          <div class="bg-white rounded-xl p-6 border border-gray-100">
            <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-heading font-bold mb-4">{item.step}</div>
            <h3 class="text-lg font-heading font-bold text-dark mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-main max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-8 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <details class="bg-light rounded-xl border border-gray-100 group">
            <summary class="px-6 py-4 cursor-pointer font-heading font-bold text-dark flex justify-between items-center">
              {faq.q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-4 text-gray-600 leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer slot="footer" />
</BaseLayout>
