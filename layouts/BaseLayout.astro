---
import { BRAND } from '../config/brand';
import CookieBanner from '../components/CookieBanner.astro';
import StickyMobileCta from '../components/StickyMobileCta.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = `${BRAND.NAME} — Professional exterior cleaning services in ${BRAND.SERVICE_AREA}. Roof, gutter, solar panel and facade cleaning using pure water technology.` } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | {BRAND.NAME}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": BRAND.NAME,
      "description": description,
      "url": `https://${BRAND.DOMAIN}`,
      "telephone": BRAND.PHONE,
      "email": BRAND.EMAIL,
      "areaServed": BRAND.AREAS.map(a => ({ "@type": "City", "name": a })),
      "serviceType": BRAND.SERVICES.map(s => s.name),
    })} />
  </head>
  <body class="bg-light text-dark font-body antialiased pb-16 lg:pb-0">
    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
    <StickyMobileCta />
    <CookieBanner />
  </body>
</html>
